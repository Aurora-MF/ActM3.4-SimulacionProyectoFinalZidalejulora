<?xml version="1.0"?>
<robot name="Puzzlebot_Jetson_Lidar_Ed.">

  <!-- LINK BASE FOOTPRINT (necesario para Gazebo) -->
  <link name="base_footprint">
    <inertial>
      <mass value="0.01"/>
      <inertia ixx="1e-5" ixy="0.0" ixz="0.0" iyy="1e-5" iyz="0.0" izz="1e-5"/>
    </inertial>
  </link>

  <!-- BASE LINK -->
  <link name="base_link">
    <visual>
      <origin xyz="0.050 0 0.0965" rpy="1.5708 0 3.1416"/>
      <geometry>
        <mesh filename="package://puzzlebot_sim/meshes/MCR2_puzzlebot_jetson_lidar_base.stl"/>
      </geometry>
      <material name="strong_blue">
        <color rgba="0.0 0.0 0.8 1.0"/>
      </material>
    </visual>
  </link>

  <!-- RUEDA IZQUIERDA -->
  <link name="wheel_left_link">
    <visual>
      <origin xyz="0 0 0" rpy="-1.57 0 0" />
      <geometry>
        <mesh filename="package://puzzlebot_sim/meshes/Puzzlebot_Wheel.stl"/>
      </geometry>
      <material name="strong_blue">
        <color rgba="0.0 0.0 0.8 1.0"/>
      </material>
    </visual>
  </link>

  <!-- RUEDA DERECHA -->
  <link name="wheel_right_link">
    <visual>
      <origin xyz="0 0 0" rpy="1.57 0 0" />
      <geometry>
        <mesh filename="package://puzzlebot_sim/meshes/Puzzlebot_Wheel.stl"/>
      </geometry>
      <material name="strong_blue">
        <color rgba="0.0 0.0 0.8 1.0"/>
      </material>
    </visual>
  </link>

  <!-- CASTER -->
  <link name="caster_holder_link">
    <visual>
      <origin xyz="0 0 -0.015" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://puzzlebot_sim/meshes/Puzzlebot_Caster_Wheel.stl"/>
      </geometry>
      <material name="strong_blue">
        <color rgba="0.0 0.0 0.8 1.0"/>
      </material>
    </visual>
  </link>

  <!-- SOPORTES EXTRA (sin visual por ahora) -->
  <link name="camera_base_link"/>
  <link name="lidar_base_link"/>

  <!-- JOINTS -->

  <joint name="base_link_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0.05" rpy="0 0 0"/>
  </joint>

  <joint name="wheel_right_joint" type="continuous">
    <parent link="base_link"/> 
    <child link="wheel_right_link"/> 
    <origin xyz="0.052 -0.095 -0.0025" rpy="0 0 0"/>
    <axis xyz="0 -1 0"/> 
  </joint>

  <joint name="wheel_left_joint" type="continuous">
    <parent link="base_link"/>
    <child link="wheel_left_link"/>
    <origin xyz="0.052 0.095 -0.0025" rpy="0 0 0"/>
    <axis xyz="0 -1 0"/>
  </joint>

  <joint name="caster_holder_joint" type="fixed">
    <parent link="base_link"/>
    <child link="caster_holder_link"/>
    <origin xyz="-0.095 0 -0.0307" rpy="0 0 0"/>
  </joint>

  <joint name="camera_base_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_base_link"/>
    <origin xyz="0.112 0 0.065" rpy="0 0 0"/>
  </joint>

  <joint name="lidar_base_joint" type="fixed">
    <parent link="base_link"/>
    <child link="lidar_base_link"/>
    <origin xyz="0.05 0 0.110" rpy="0 0 0"/>
  </joint>

</robot>